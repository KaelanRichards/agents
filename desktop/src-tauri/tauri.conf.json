{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Agents",
	"version": "0.1.0",
	"identifier": "dev.kaelan.agents",
	"build": {
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "Agents",
				"width": 1080,
				"height": 720,
				"minWidth": 760,
				"minHeight": 480,
				"resizable": true,
				"fullscreen": false,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true
			}
		],
		"security": {
			"csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["app", "dmg"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.png"
		]
	},
	"plugins": {}
}
