// zellij config — sensible defaults for remote agent sessions.
// Symlinked to ~/.config/zellij/config.kdl by bootstrap.sh.

default_shell "zsh"
copy_on_select true
mouse_mode true
pane_frames true
scrollback_editor "nvim"

// resume panes/layout after a restart (handy for long-running remote work)
session_serialization true
serialize_pane_viewport true

theme "catppuccin-mocha"
