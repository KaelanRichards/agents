# Copy to ~/.config/agents-secrets/windmill-oauth.env and fill values.
# Do not commit the real file.
#
# Google can use one OAuth web client for both Gmail and Calendar if both APIs are enabled
# and both redirect URIs are allowed:
#   http://localhost:8790/oauth/callback/gmail
#   http://localhost:8790/oauth/callback/gcal
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional: override the shared Google client for either resource.
WINDMILL_GMAIL_OAUTH_CLIENT_ID=
WINDMILL_GMAIL_OAUTH_CLIENT_SECRET=
WINDMILL_GCAL_OAUTH_CLIENT_ID=
WINDMILL_GCAL_OAUTH_CLIENT_SECRET=

# Slack app OAuth credentials for the Windmill app.
# For a localhost-only setup, Slack callbacks must still be publicly reachable if you use
# Slack OAuth. A pre-minted bot token can be used via Windmill CLI instead.
WINDMILL_SLACK_OAUTH_CLIENT_ID=
WINDMILL_SLACK_OAUTH_CLIENT_SECRET=
