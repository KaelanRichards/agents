# 1Password references for the shared agents system.
# Put the real items in a dedicated vault, then create:
#   ~/.config/agents-secrets/agents.1password.env
# from this shape. Values here are references, not secrets.

# Personal actions facade.
PERSONAL_ACTIONS_PROVIDER=op://Agents System/personal-actions/provider
PERSONAL_ACTIONS_WEBHOOK_URL=op://Agents System/personal-actions/webhook_url
PERSONAL_ACTIONS_WEBHOOK_TOKEN=op://Agents System/personal-actions/webhook_token
PERSONAL_ACTIONS_WEBHOOK_HMAC_SECRET=op://Agents System/personal-actions/webhook_hmac_secret
PERSONAL_ACTIONS_DRY_RUN=op://Agents System/personal-actions/dry_run
PERSONAL_ACTIONS_ALLOW_HTTP=op://Agents System/personal-actions/allow_http
PERSONAL_ACTIONS_REQUIRE_APPROVAL=op://Agents System/personal-actions/require_approval

# Gmail OAuth used by the constrained personal-actions facade.
PERSONAL_GMAIL_COMPOSE_CLIENT_ID=op://Agents System/gmail-compose/client_id
PERSONAL_GMAIL_COMPOSE_CLIENT_SECRET=op://Agents System/gmail-compose/client_secret
PERSONAL_GMAIL_COMPOSE_REFRESH_TOKEN=op://Agents System/gmail-compose/refresh_token
PERSONAL_GMAIL_MODIFY_CLIENT_ID=op://Agents System/gmail-modify/client_id
PERSONAL_GMAIL_MODIFY_CLIENT_SECRET=op://Agents System/gmail-modify/client_secret
PERSONAL_GMAIL_MODIFY_REFRESH_TOKEN=op://Agents System/gmail-modify/refresh_token
PERSONAL_WORK_GMAIL_COMPOSE_CLIENT_ID=op://Agents System/work-gmail-compose/client_id
PERSONAL_WORK_GMAIL_COMPOSE_CLIENT_SECRET=op://Agents System/work-gmail-compose/client_secret
PERSONAL_WORK_GMAIL_COMPOSE_REFRESH_TOKEN=op://Agents System/work-gmail-compose/refresh_token
PERSONAL_WORK_GMAIL_MODIFY_CLIENT_ID=op://Agents System/work-gmail-modify/client_id
PERSONAL_WORK_GMAIL_MODIFY_CLIENT_SECRET=op://Agents System/work-gmail-modify/client_secret
PERSONAL_WORK_GMAIL_MODIFY_REFRESH_TOKEN=op://Agents System/work-gmail-modify/refresh_token

# Local Windmill admin and OAuth provider setup.
WINDMILL_BASE_URL=op://Agents System/windmill-admin/base_url
WINDMILL_ADMIN_EMAIL=op://Agents System/windmill-admin/admin_email
WINDMILL_ADMIN_PASSWORD=op://Agents System/windmill-admin/admin_password
WINDMILL_WORKSPACE=op://Agents System/windmill-admin/workspace
GOOGLE_OAUTH_CLIENT_ID=op://Agents System/windmill-oauth/google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=op://Agents System/windmill-oauth/google_client_secret
WINDMILL_GMAIL_OAUTH_CLIENT_ID=op://Agents System/windmill-oauth/gmail_client_id
WINDMILL_GMAIL_OAUTH_CLIENT_SECRET=op://Agents System/windmill-oauth/gmail_client_secret
WINDMILL_GCAL_OAUTH_CLIENT_ID=op://Agents System/windmill-oauth/gcal_client_id
WINDMILL_GCAL_OAUTH_CLIENT_SECRET=op://Agents System/windmill-oauth/gcal_client_secret
WINDMILL_SLACK_OAUTH_CLIENT_ID=op://Agents System/windmill-oauth/slack_client_id
WINDMILL_SLACK_OAUTH_CLIENT_SECRET=op://Agents System/windmill-oauth/slack_client_secret

# Local Windmill stack and dashboard controls.
POSTGRES_PASSWORD=op://Agents System/windmill-stack/postgres_password
WEBDASH_TOKEN=op://Agents System/webdash/token
HCLOUD_TOKEN=op://Agents System/hetzner/api_token
