{
	"mcpServers": {
		"context7": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp@3.0.0"]
		},
		"playwright": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@playwright/mcp@0.0.75"]
		},
		"filesystem": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem@2026.1.14",
				"$HOME/code"
			]
		},
		"sequential-thinking": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking@2025.12.18"
			]
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/",
			"bearer_token_env_var": "GITHUB_PAT"
		},
		"agents": {
			"type": "stdio",
			"command": "agents-mcp",
			"args": []
		},
		"agent-broker": {
			"type": "stdio",
			"command": "$AGENTS_HOME/bin/agent-broker-mcp",
			"args": []
		},
		"personal-actions": {
			"type": "stdio",
			"command": "$AGENTS_HOME/bin/personal-actions-mcp",
			"args": []
		},
		"linear": {
			"type": "http",
			"url": "https://mcp.linear.app/mcp"
		},
		"bigquery": {
			"type": "stdio",
			"command": "$AGENTS_HOME/bin/bigquery-mcp",
			"args": []
		},
		"datadog": {
			"type": "http",
			"url": "https://mcp.us5.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=core,apm,error-tracking,software-delivery"
		},
		"sentry": {
			"type": "http",
			"url": "https://mcp.sentry.dev/mcp"
		}
	}
}
