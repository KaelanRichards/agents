# Local-only Windmill backend for personal-actions-mcp.
#
# Copy to .env and change POSTGRES_PASSWORD before first start:
#   cp stacks/windmill/.env.example stacks/windmill/.env
#
# The helper `windmill-up` does this automatically and generates a password.

WM_IMAGE=ghcr.io/windmill-labs/windmill:main
POSTGRES_PASSWORD=change-me-before-first-start
DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@postgres:5432/windmill
BASE_URL=http://localhost:8790
WINDMILL_PORT=8790
