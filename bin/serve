#!/usr/bin/env bash
# serve — run webdash as an always-on user service + (if Tailscale is up) expose it on the tailnet.
# Linux/systemd (the VM). Re-run after config changes. Idempotent.
set -euo pipefail
U="$(id -un)"

mkdir -p "$HOME/.config/systemd/user"
cp "$HOME/.config/agents/systemd/webdash.service" "$HOME/.config/systemd/user/webdash.service"

# let the user service run without an active login session (survives logout / boots at startup)
sudo loginctl enable-linger "$U" 2>/dev/null || loginctl enable-linger "$U" 2>/dev/null || true
systemctl --user daemon-reload
systemctl --user enable --now webdash.service
echo "webdash.service: $(systemctl --user is-active webdash.service)"

if command -v tailscale >/dev/null 2>&1 && tailscale status >/dev/null 2>&1; then
  echo "==> exposing on the tailnet (tailnet members only, HTTPS)"
  tailscale serve --bg 8787 2>&1 || tailscale serve --bg http://127.0.0.1:8787 2>&1 || true
  tailscale serve status 2>&1 || true
else
  echo "Tailscale not ready — install + auth, then re-run 'serve':"
  echo "  curl -fsSL https://tailscale.com/install.sh | sh"
  echo "  sudo tailscale up"
fi
