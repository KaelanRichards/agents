#!/usr/bin/env bash
# obs — local OpenTelemetry stack for agent observability (cost / tokens / usage).
# Start the stack, then `eval "$(obs env)"` to point Claude Code at it.
#
#   obs up      start collector + Prometheus + Grafana (needs Docker/OrbStack); marks telemetry on
#   obs down    stop the stack and mark telemetry off
#   obs on      mark telemetry on (new agent shells export OTEL_*) without starting the stack
#   obs off     mark telemetry off
#   obs status  show stack + telemetry marker state
#   obs open    open Grafana (http://localhost:3000, anonymous admin)
#   obs env     print the env exports that enable Claude Code telemetry
set -euo pipefail
DIR="$HOME/.config/agents/observability"
MARK="$DIR/.telemetry-on"   # gitignored; agents.env.zsh exports OTEL_* when this exists

case "${1:-}" in
  up)
    docker compose -f "$DIR/docker-compose.yml" up -d
    touch "$MARK"
    echo "Grafana:    http://localhost:3000  (anonymous admin)"
    echo "Prometheus: http://localhost:9090"
    echo "telemetry:  on (restart agent shells, or run: eval \"\$(obs env)\")"
    echo "Then explore metrics named  claude_code.*  in Grafana."
    ;;
  down) docker compose -f "$DIR/docker-compose.yml" down; rm -f "$MARK"; echo "telemetry: off" ;;
  on) touch "$MARK"; echo "telemetry: on (restart agent shells to export OTEL_*)" ;;
  off) rm -f "$MARK"; echo "telemetry: off" ;;
  status)
    [ -f "$MARK" ] && echo "telemetry marker: on" || echo "telemetry marker: off"
    docker compose -f "$DIR/docker-compose.yml" ps 2>/dev/null || echo "(docker unavailable)"
    ;;
  open) open http://localhost:3000 2>/dev/null || xdg-open http://localhost:3000 2>/dev/null || echo "open http://localhost:3000" ;;
  env)
    cat <<'ENV'
export CLAUDE_CODE_ENABLE_TELEMETRY=1
export OTEL_METRICS_EXPORTER=otlp
export OTEL_LOGS_EXPORTER=otlp
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc
export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
export OTEL_METRIC_EXPORT_INTERVAL=10000
ENV
    ;;
  *) echo "usage: obs up|down|on|off|status|open|env" >&2; exit 1 ;;
esac
