#!/usr/bin/env bash
# hermes-sync — generate ~/.hermes/config.yaml from the shared agents policy.
set -euo pipefail

AH="${AGENTS_HOME:-$HOME/.config/agents}"
HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
config="$HERMES_HOME/config.yaml"

mkdir -p "$HERMES_HOME" "$AH/assistant/logs"
if [ -f "$config" ]; then
	cp "$config" "$config.hermes-sync.bak"
fi

# Collect curated memory files so new ones flow in automatically (no hardcoding).
mem_files=""
for f in "$AH"/assistant/memory/*.md; do
	[ -e "$f" ] || continue
	mem_files+="  - \"$f\""$'\n'
done
mem_files="${mem_files%$'\n'}"

# Pull the remote MCP endpoints from the canonical mcp.json so hermes-sync stays a single source
# of truth (the pinned Datadog US5 toolsets and Sentry URL live there, not duplicated here).
# Resolve a server's remote endpoint: prefer .url, else the first https:// arg. mcp-remote stdio
# bridges (Sentry, etc.) carry the real URL as an arg, not a .url key — without the fallback,
# Sentry was silently dropped from the Hermes config entirely.
mcp_endpoint() {
	python3 - "$AH/mcp.json" "$1" <<'PY' 2>/dev/null || true
import json, sys

cfg = json.load(open(sys.argv[1]))["mcpServers"].get(sys.argv[2], {})
url = cfg.get("url") or ""
if not url:
    for a in cfg.get("args", []):
        if isinstance(a, str) and a.startswith("https://"):
            url = a
            break
print(url)
PY
}
dd_url="$(mcp_endpoint datadog)"
sentry_url="$(mcp_endpoint sentry)"

# Datadog: read-first observability. include-list = read-only tools only (no create/update/upsert/
# mute/retry), enforcing assistant/policy.md "Datadog MCP" section at the tool-surface level.
datadog_block=""
if [ -n "$dd_url" ]; then
	datadog_block="$(
		cat <<DDEOF

  datadog:
    type: "http"
    url: "$dd_url"
    tools:
      include:
        - search_datadog_logs
        - get_datadog_metric
        - search_datadog_metrics
        - search_datadog_spans
        - get_datadog_trace
        - search_datadog_monitors
        - search_datadog_incidents
        - get_datadog_incident
        - search_datadog_services
        - search_datadog_dashboards
        - get_datadog_dashboard
        - search_datadog_error_tracking_issues
        - get_datadog_error_tracking_issue
        - search_datadog_hosts
        - search_datadog_events
      prompts: false
      resources: false
DDEOF
	)"
fi

# Sentry: read-first app debugging. include-list = read-only tools only (no resolve/assign/
# ignore/update), enforcing assistant/policy.md "Sentry MCP" section at the tool-surface level.
sentry_block=""
if [ -n "$sentry_url" ]; then
	sentry_block="$(
		cat <<SENTRYEOF

  sentry:
    type: "http"
    url: "$sentry_url"
    tools:
      include:
        - whoami
        - find_organizations
        - find_projects
        - find_teams
        - find_releases
        - search_issues
        - search_events
        - search_issue_events
        - get_issue_tag_values
        - get_sentry_resource
        - analyze_issue_with_seer
      prompts: false
      resources: false
SENTRYEOF
	)"
fi

cat >"$config" <<EOF
# Managed by hermes-sync. Edit ~/.config/agents/assistant/* or env vars, then rerun hermes-sync.
#
# Personal actions are served by the local personal-actions-mcp facade.
# It defaults to dry-run unless a live provider is configured, for example:
#   personal-actions-configure --url 'https://...' --live
#
# The facade exposes only:
#   Slack send/search messages
#   Gmail search/read/create draft/send/move exact message id to Trash
#   Google Calendar list/create/update events
#   Google Drive search files
#
# Read-only investigation MCPs (bigquery/datadog/sentry) mirror the policy in
# assistant/policy.md and are constrained to read-only tools at the include-list level.

terminal:
  backend: "local"
  cwd: "$HOME"
  timeout: 180
  docker_mount_cwd_to_workspace: false
  lifetime_seconds: 300

model:
  provider: "openai-codex"
  name: "gpt-5.5"
  # Use the user's Codex CLI / ChatGPT subscription for OpenAI-scoped turns.
  openai_runtime: "codex_app_server"

mcp_servers:
  agents_readonly:
    command: "agents-mcp"
    args: []
    env:
      AGENTS_MCP_ALLOW_MUTATION: "0"
    tools:
      include:
        - repo_status
        - repo_log
        - repo_diff
        - list_tasks
        - list_mcp_servers
      prompts: false
      resources: false

  personal_actions:
    command: "$AH/bin/personal-actions-mcp"
    args: []
    enabled: true
    tools:
      include:
        - personal_slack_send_message
        - personal_slack_search_messages
        - personal_gmail_search_messages
        - personal_gmail_get_message
        - personal_gmail_create_draft
        - personal_gmail_send_email
        - personal_gmail_trash_email
        - personal_calendar_list_events
        - personal_calendar_create_event
        - personal_calendar_update_event
        - personal_drive_search_files
      prompts: false
      resources: false

  bigquery:
    command: "bigquery-mcp"
    args: []
    tools:
      include:
        - bigquery_execute_sql_readonly
        - bigquery_estimate_query
        - bigquery_list_datasets
        - bigquery_list_tables
        - bigquery_show_table_schema
      prompts: false
      resources: false
$datadog_block
$sentry_block

context_files:
  - "$AH/AGENTS.md"
  - "$AH/assistant/policy.md"
$mem_files
EOF

echo "wrote $config"
echo "personal_actions enabled via personal-actions-mcp (dry-run unless a live provider is configured)"
echo "read-only investigation MCPs: bigquery${dd_url:+, datadog}${sentry_url:+, sentry} (read-only tool allowlists)"
