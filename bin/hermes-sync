#!/usr/bin/env bash
# hermes-sync — generate ~/.hermes/config.yaml from the shared agents policy.
set -euo pipefail

AH="${AGENTS_HOME:-$HOME/.config/agents}"
HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
config="$HERMES_HOME/config.yaml"

mkdir -p "$HERMES_HOME" "$AH/assistant/logs"
if [ -f "$config" ]; then
	cp "$config" "$config.hermes-sync.bak"
fi

cat > "$config" <<EOF
# Managed by hermes-sync. Edit ~/.config/agents/assistant/* or env vars, then rerun hermes-sync.
#
# Personal actions are served by the local personal-actions-mcp facade.
# It defaults to dry-run unless a live provider is configured, for example:
#   export PERSONAL_ACTIONS_PROVIDER=webhook
#   export PERSONAL_ACTIONS_WEBHOOK_URL='https://...'
#   export PERSONAL_ACTIONS_WEBHOOK_TOKEN='...'
#   export PERSONAL_ACTIONS_DRY_RUN=0
#
# The facade exposes only:
#   Slack send message
#   Gmail create draft / send email
#   Google Calendar create event / update event

terminal:
  backend: "local"
  cwd: "$HOME"
  timeout: 180
  docker_mount_cwd_to_workspace: false
  lifetime_seconds: 300

model:
  provider: "openai-codex"
  name: "gpt-5.5"
  # Use the user's Codex CLI / ChatGPT subscription for OpenAI-scoped turns.
  openai_runtime: "codex_app_server"

mcp_servers:
  agents_readonly:
    command: "agents-mcp"
    args: []
    env:
      AGENTS_MCP_ALLOW_MUTATION: "0"
    tools:
      include:
        - repo_status
        - repo_log
        - repo_diff
        - list_tasks
        - list_mcp_servers
      prompts: false
      resources: false

  personal_actions:
    command: "$AH/bin/personal-actions-mcp"
    args: []
    enabled: true
    tools:
      include:
        - personal_slack_send_message
        - personal_gmail_create_draft
        - personal_gmail_send_email
        - personal_calendar_create_event
        - personal_calendar_update_event
      prompts: false
      resources: false

context_files:
  - "$AH/AGENTS.md"
  - "$AH/assistant/policy.md"
  - "$AH/assistant/memory/preferences.md"
  - "$AH/assistant/memory/people.md"
  - "$AH/assistant/memory/projects.md"
EOF

echo "wrote $config"
echo "personal_actions enabled via personal-actions-mcp (dry-run unless a live provider is configured)"
