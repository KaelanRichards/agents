#!/usr/bin/env bash
# toolbelt-diff — compare the Brewfile and flake.nix package lists and warn on drift.
# Both files describe the same shared CLI toolbelt; they should stay in sync.
# Maps brew formula names to nixpkgs attribute names for known equivalents (e.g. ripgrep,
# git-delta -> delta, yq -> yq-go, ast-grep, jj <-> jujutsu).
set -euo pipefail
AH="${AGENTS_HOME:-$HOME/.config/agents}"
brewfile="$AH/Brewfile"
flake="$AH/flake.nix"

[ -f "$brewfile" ] || {
	echo "missing $brewfile" >&2
	exit 1
}
[ -f "$flake" ] || {
	echo "missing $flake" >&2
	exit 1
}

# brew formula -> canonical name (used for matching).
canonical() {
	case "$1" in
	git-delta) echo "delta" ;;
	yq) echo "yq-go" ;;
	jj) echo "jujutsu" ;;
	*) echo "$1" ;;
	esac
}

# Brewfile: lines like  brew "name"
brew_list=$(awk -F'"' '/^brew /{print $2}' "$brewfile" | sort -u)

# flake.nix: tokens inside `packages = with pkgs; [ ... ]`. Strip Nix comments and brackets.
flake_list=$(awk '
  /packages = with pkgs;/{cap=1; next}
  cap && /\];/         {cap=0}
  cap                  {sub(/#.*/,""); for(i=1;i<=NF;i++) if($i!~/^[\[\];]?$/) print $i}
' "$flake" | sort -u)

only_in_brew=""
only_in_flake="$flake_list"
for b in $brew_list; do
	c=$(canonical "$b")
	if ! echo "$flake_list" | grep -qx -- "$c"; then
		only_in_brew="$only_in_brew $b"
	else
		only_in_flake=$(echo "$only_in_flake" | grep -vx -- "$c" || true)
	fi
done

# Filter flake-only set to drop things we don't track in brew on purpose
# (language toolchains and provisioning helpers that brew installs separately or skips).
flake_only_filtered=""
for f in $only_in_flake; do
	case "$f" in
	# These are intentionally only in the Nix shell or installed elsewhere.
	hcloud | git) continue ;; # actionlint now in Brewfile too (just test needs it on brew hosts)
	esac
	flake_only_filtered="$flake_only_filtered $f"
done

err=0
if [ -n "$only_in_brew" ]; then
	echo "Only in Brewfile (consider adding to flake.nix):"
	for x in $only_in_brew; do echo "  - $x"; done
	err=1
fi
if [ -n "$flake_only_filtered" ]; then
	echo "Only in flake.nix (consider adding to Brewfile):"
	for x in $flake_only_filtered; do echo "  - $x"; done
	err=1
fi

[ "$err" = 0 ] && echo "✓ toolbelt-diff: Brewfile and flake.nix are in sync"
exit "$err"
