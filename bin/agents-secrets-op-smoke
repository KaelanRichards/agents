#!/usr/bin/env bash
# agents-secrets-op-smoke — resolve 1Password refs and print presence only.
set -euo pipefail

env_file="${AGENTS_1PASSWORD_ENV_FILE:-$HOME/.config/agents-secrets/agents.1password.env}"

exec agents-secrets-op-run --env-file "$env_file" -- python3 -c '
import os

required = [
    "PERSONAL_ACTIONS_PROVIDER",
    "PERSONAL_ACTIONS_WEBHOOK_URL",
    "PERSONAL_ACTIONS_WEBHOOK_TOKEN",
    "PERSONAL_ACTIONS_WEBHOOK_HMAC_SECRET",
]

missing = [key for key in required if not os.environ.get(key)]
for key in required:
    print(f"{key}=present" if key not in missing else f"{key}=missing")
raise SystemExit(1 if missing else 0)
'
