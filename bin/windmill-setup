#!/usr/bin/env bash
# windmill-setup — print the manual Windmill setup checklist for personal-actions.
set -euo pipefail

cat <<'EOF'
Windmill personal-actions setup

1. Start Windmill:
   windmill-up

2. Bootstrap the local workspace, script, webhook, and secrets:
   windmill-bootstrap

3. Open http://localhost:8790 and sign in.
   Credentials are stored in:
   ~/.config/agents-secrets/windmill-admin.env

4. In Windmill, create OAuth resources:
   - Slack resource for sending messages
   - Gmail or Google Workspace resource for draft/send
   - Google Calendar resource for event create/update

5. Confirm the resource paths match the handler defaults, or edit the script defaults:
   - u/admin/slack
   - u/admin/gmail
   - u/admin/gcal

6. Run:
   personal-actions-check

7. After OAuth resources are connected, set:
   PERSONAL_ACTIONS_DRY_RUN=0
   in ~/.config/agents-secrets/personal-actions.env

Keep Windmill MCP disabled for Claude/Codex until the narrow webhook path is proven.
EOF
