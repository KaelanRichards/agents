#!/usr/bin/env bash
# personal-actions-configure — create/update local webhook config without committing secrets.
set -euo pipefail

AH="${AGENTS_HOME:-$HOME/.config/agents}"
env_file="${PERSONAL_ACTIONS_ENV_FILE:-$HOME/.config/agents-secrets/personal-actions.env}"
url=""
dry_run="1"
allow_http="${PERSONAL_ACTIONS_ALLOW_HTTP:-0}"

usage() {
	cat >&2 <<'EOF'
usage: personal-actions-configure [--url https://...] [--live|--dry-run]

Writes ~/.config/agents-secrets/personal-actions.env with a generated bearer token
and HMAC secret. The file is outside the repo and chmod 600.
EOF
}

while [ "$#" -gt 0 ]; do
	case "$1" in
		--url)
			[ "$#" -ge 2 ] || { usage; exit 2; }
			url="$2"
			shift 2
			;;
		--live)
			dry_run="0"
			shift
			;;
		--dry-run)
			dry_run="1"
			shift
			;;
		-h|--help)
			usage
			exit 0
			;;
		*)
			usage
			exit 2
			;;
	esac
done

if [ -n "$url" ] && [[ "$url" != https://* ]] && [ "${PERSONAL_ACTIONS_ALLOW_HTTP:-0}" != "1" ]; then
	echo "personal-actions-configure: webhook URL must be https:// unless PERSONAL_ACTIONS_ALLOW_HTTP=1" >&2
	exit 2
fi
if [ -n "$url" ] && [[ "$url" != https://* ]]; then
	allow_http="1"
fi

mkdir -p "$(dirname "$env_file")"
token="$(openssl rand -hex 32)"
hmac_secret="$(openssl rand -hex 32)"
umask 077
cat >"$env_file" <<EOF
# Generated by personal-actions-configure. Do not commit this file.
PERSONAL_ACTIONS_PROVIDER=webhook
PERSONAL_ACTIONS_WEBHOOK_URL=$url
PERSONAL_ACTIONS_WEBHOOK_TOKEN=$token
PERSONAL_ACTIONS_WEBHOOK_HMAC_SECRET=$hmac_secret
PERSONAL_ACTIONS_DRY_RUN=$dry_run
PERSONAL_ACTIONS_ALLOW_HTTP=$allow_http
EOF
chmod 600 "$env_file"

echo "wrote $env_file"
if [ -z "$url" ]; then
	echo "webhook URL is blank; rerun with --url https://... when Pipedream is ready"
fi
if [ "$dry_run" = "0" ]; then
	echo "live mode enabled"
else
	echo "dry-run mode enabled"
fi
