#!/usr/bin/env bash
# agents-secrets-op-check — report 1Password readiness for the shared agents system.
set -uo pipefail

ok() { printf '  [ ok ] %s\n' "$1"; }
warn() { printf '  [warn] %s\n' "$1"; }
bad() { printf '  [FAIL] %s\n' "$1"; }

env_file="${AGENTS_1PASSWORD_ENV_FILE:-$HOME/.config/agents-secrets/agents.1password.env}"
bootstrap_file="${AGENTS_1PASSWORD_BOOTSTRAP_ENV:-$HOME/.config/agents-secrets/1password-bootstrap.env}"

echo "== 1Password CLI =="
if command -v op >/dev/null 2>&1; then
	ok "op present ($(op --version 2>/dev/null | head -1))"
else
	bad "op CLI missing (install 1password-cli)"
	exit 1
fi

if [ -n "${OP_SERVICE_ACCOUNT_TOKEN:-}" ]; then
	ok "OP_SERVICE_ACCOUNT_TOKEN present in environment"
elif [ -f "$bootstrap_file" ]; then
	mode="$(stat -f '%Lp' "$bootstrap_file" 2>/dev/null || stat -c '%a' "$bootstrap_file" 2>/dev/null || true)"
	if [ "$mode" = "600" ]; then
		ok "bootstrap env present with mode 600"
	else
		warn "bootstrap env mode is ${mode:-unknown}; expected 600"
	fi
elif op account list --format json 2>/dev/null | jq -e 'length > 0' >/dev/null 2>&1; then
	ok "interactive 1Password account configured"
else
	warn "no 1Password account/session or service-account bootstrap configured"
fi

echo "== agents 1Password env refs =="
if [ -f "$env_file" ]; then
	ok "env ref file present: ${env_file/#"$HOME"/~}"
	if awk -F= '/^[A-Za-z_][A-Za-z0-9_]*=/ && $2 !~ /^op:\/\// {bad=1} END {exit bad?0:1}' "$env_file"; then
		warn "env ref file contains non-op:// values; keep only references here"
	else
		ok "env ref file contains only op:// values"
	fi
	count="$(awk -F= '/^[A-Za-z_][A-Za-z0-9_]*=op:\/\// {n++} END {print n+0}' "$env_file")"
	ok "$count 1Password-backed variables declared"
else
	warn "missing env ref file: ${env_file/#"$HOME"/~}"
	warn "template: ~/.config/agents/assistant/1password/agents.1password.env.example"
fi

echo "== legacy plaintext env files =="
for f in "$HOME/.config/agents-secrets"/*.env; do
	[ -f "$f" ] || continue
	case "$f" in
	*agents.1password.env | *1password-bootstrap.env) continue ;;
	esac
	mode="$(stat -f '%Lp' "$f" 2>/dev/null || stat -c '%a' "$f" 2>/dev/null || true)"
	printf '  [info] %s mode=%s\n' "${f/#"$HOME"/~}" "${mode:-unknown}"
done
