#!/usr/bin/env bash
# mcp-sync — one source of truth for MCP servers across Claude Code + Codex CLI.
#
# Canonical: ~/.config/agents/mcp.json
#   { "mcpServers": { "<name>": <def> } }
#   stdio def: { "type":"stdio", "command":"npx", "args":["-y","pkg"], "env":{"K":"V"} }
#   http  def: { "type":"http",  "url":"https://host/mcp", "headers":{"K":"V"},
#               "bearer_token_env_var":"TOKEN_ENV" }   # bearer maps per-tool (see below)
#
# Generates from the canonical file:
#   - Claude: ~/.claude.json        -> top-level "mcpServers" (user scope, all projects)
#             (bearer_token_env_var -> Authorization: "Bearer ${VAR}" header)
#   - Codex : ~/.codex/config.toml  -> a managed [mcp_servers.*] block
#             (bearer_token_env_var -> native bearer_token_env_var key)
#
# Usage:
#   mcp-sync                              regenerate both tool configs from canonical
#   mcp-sync list                         list canonical servers
#   mcp-sync add  <name> -- <cmd...>      add a stdio server, then sync
#   mcp-sync add-http <name> <url> [ENV]  add an http server (optional bearer env var), then sync
#   mcp-sync remove <name>                remove a server, then sync
#   mcp-sync check                        validate canonical JSON + show effective config (no writes)
#   mcp-sync drift                        report npm pkg drift for stdio MCP packages
#
# Path placeholders in the canonical JSON (mcp.json) are expanded at write time:
#   $AGENTS_HOME  -> ~/.config/agents (or $AGENTS_HOME env)
#   $HOME         -> $HOME
# Optional per-machine overlay: mcp.local.json (gitignored) is merged into canonical,
# overriding by server name. Use it for hosts where a server lives at a non-portable path.
set -euo pipefail

AGENTS_HOME="${AGENTS_HOME:-$HOME/.config/agents}"
CANON="$AGENTS_HOME/mcp.json"
LOCAL_OVERLAY="$AGENTS_HOME/mcp.local.json"   # optional per-machine overlay (gitignored)
CLAUDE_JSON="$HOME/.claude.json"
CODEX_TOML="$HOME/.codex/config.toml"
BEGIN="# >>> mcp-sync (managed: edit ~/.config/agents/mcp.json then run mcp-sync) >>>"
END="# <<< mcp-sync <<<"

command -v jq >/dev/null || { echo "mcp-sync: jq is required" >&2; exit 1; }
mkdir -p "$AGENTS_HOME" "$HOME/.codex"
[ -f "$CANON" ] || echo '{"mcpServers":{}}' > "$CANON"

build_effective() {
  # Compose the effective config (canonical ⊕ optional local overlay) and expand
  # $AGENTS_HOME / $HOME placeholders in string fields. Claude/Codex don't shell-expand
  # the `command` field, so paths must be absolute at write time.
  local out="$1"
  local merged
  merged=$(mktemp)
  if [ -f "$LOCAL_OVERLAY" ]; then
    jq -s '.[0].mcpServers as $a | (.[1].mcpServers // {}) as $b | {mcpServers: ($a + $b)}' "$CANON" "$LOCAL_OVERLAY" > "$merged"
  else
    cp "$CANON" "$merged"
  fi
  jq --arg AH "$AGENTS_HOME" --arg H "$HOME" '
    def expand: if type=="string" then (gsub("\\$AGENTS_HOME"; $AH) | gsub("\\$HOME"; $H)) else . end;
    .mcpServers |= with_entries(.value |= (
        (if has("command") then .command |= expand else . end)
      | (if has("url")     then .url     |= expand else . end)
      | (if has("args")    then .args    |= (if type=="array" then map(expand) else . end) else . end)
      | (if has("env")     then .env     |= (if type=="object" then with_entries(.value |= (expand | if type=="string" then . else tostring end)) else . end) else . end)
    ))
  ' "$merged" > "$out"
  rm -f "$merged"
}

cmd="${1:-sync}"
if [ $# -gt 0 ]; then shift; fi

# Server names become TOML table keys and Claude object keys. Keep them to a safe charset so a
# name can never need exotic quoting (and so a typo can't silently mis-register on one client).
valid_name() {
  case "$1" in
    '' ) echo "mcp-sync: server name must not be empty" >&2; return 1 ;;
    *[!A-Za-z0-9_-]* ) echo "mcp-sync: invalid server name '$1' (allowed: letters, digits, '_', '-')" >&2; return 1 ;;
  esac
}

case "$cmd" in
  list)
    jq -r '.mcpServers // {} | to_entries[] | "  \(.key): \(.value.type // "stdio")  \(.value.command // .value.url // "")"' "$CANON"
    exit 0 ;;
  add)
    name="$1"; shift
    valid_name "$name" || exit 2
    if [ "${1:-}" = "--" ]; then shift; fi
    cmdbin="$1"; shift
    args=$(printf '%s\n' "$@" | jq -R . | jq -s .)
    t=$(mktemp); jq --arg n "$name" --arg c "$cmdbin" --argjson a "$args" \
      '.mcpServers[$n] = {type:"stdio", command:$c, args:$a}' "$CANON" > "$t" && mv "$t" "$CANON"
    echo "added stdio server '$name'" ;;
  add-http)
    name="$1"; url="$2"; bearer="${3:-}"
    valid_name "$name" || exit 2
    if [ -n "$bearer" ]; then
      t=$(mktemp); jq --arg n "$name" --arg u "$url" --arg b "$bearer" \
        '.mcpServers[$n] = {type:"http", url:$u, bearer_token_env_var:$b}' "$CANON" > "$t" && mv "$t" "$CANON"
    else
      t=$(mktemp); jq --arg n "$name" --arg u "$url" \
        '.mcpServers[$n] = {type:"http", url:$u}' "$CANON" > "$t" && mv "$t" "$CANON"
    fi
    echo "added http server '$name'" ;;
  remove|rm)
    name="$1"
    t=$(mktemp); jq --arg n "$name" 'del(.mcpServers[$n])' "$CANON" > "$t" && mv "$t" "$CANON"
    echo "removed '$name'" ;;
  check)
    jq -e . "$CANON" >/dev/null || { echo "ERROR: invalid JSON in $CANON" >&2; exit 1; }
    [ -f "$LOCAL_OVERLAY" ] && jq -e . "$LOCAL_OVERLAY" >/dev/null
    eff=$(mktemp); trap 'rm -f "$eff"' EXIT
    build_effective "$eff"
    echo "canonical: $CANON"
    [ -f "$LOCAL_OVERLAY" ] && echo "overlay:   $LOCAL_OVERLAY (applied)"
    echo "effective config that would be written:"
    jq . "$eff"
    exit 0 ;;
  drift)
    exec "$AGENTS_HOME/bin/mcp-update" ;;
  sync) : ;;
  help|-h|--help)
    sed -n '2,36p' "$0" | sed 's/^#\{0,1\} \{0,1\}//'; exit 0 ;;
  *) echo "mcp-sync: unknown command '$cmd' (try: mcp-sync help)" >&2; exit 1 ;;
esac

jq -e . "$CANON" >/dev/null 2>&1 || { echo "ERROR: invalid JSON in $CANON" >&2; exit 1; }
if [ -f "$LOCAL_OVERLAY" ] && ! jq -e . "$LOCAL_OVERLAY" >/dev/null 2>&1; then
  echo "ERROR: invalid JSON in $LOCAL_OVERLAY" >&2; exit 1
fi

EFFECTIVE=$(mktemp)
trap 'rm -f "$EFFECTIVE"' EXIT
build_effective "$EFFECTIVE"

# 1) Claude Code (JSON, user scope) — preserve everything else in ~/.claude.json.
#    Map bearer_token_env_var -> Authorization header with ${VAR} expansion.
#    Validate-then-swap so a broken jq template doesn't disable Claude.
if [ -f "$CLAUDE_JSON" ]; then
  cp "$CLAUDE_JSON" "$CLAUDE_JSON.mcp-sync.bak"
else
  echo '{}' > "$CLAUDE_JSON"
fi
t=$(mktemp)
jq --slurpfile c "$EFFECTIVE" '.mcpServers = (($c[0].mcpServers // {}) | map_values(
    if .bearer_token_env_var then
      (if (.headers.Authorization // null) != null
       then error("mcp-sync: server defines both a literal Authorization header and bearer_token_env_var — pick one")
       else (.headers = ((.headers // {}) + {Authorization: ("Bearer ${" + .bearer_token_env_var + "}")})) | del(.bearer_token_env_var)
       end)
    else . end))' "$CLAUDE_JSON" > "$t"
if jq -e . "$t" >/dev/null 2>&1; then
  mv "$t" "$CLAUDE_JSON"
else
  rm -f "$t"
  echo "ERROR: generated Claude JSON is invalid — left $CLAUDE_JSON unchanged" >&2
  exit 1
fi

# 2) Codex CLI (TOML) — replace only the managed block, leave the rest untouched.
[ -f "$CODEX_TOML" ] || touch "$CODEX_TOML"
cp "$CODEX_TOML" "$CODEX_TOML.mcp-sync.bak"
t=$(mktemp)
awk -v b="$BEGIN" -v e="$END" '$0==b{skip=1;next} $0==e{skip=0;next} skip!=1{print}' "$CODEX_TOML" > "$t" && mv "$t" "$CODEX_TOML"
{
  echo "$BEGIN"
  # All TOML keys (server name, env keys, header keys) are emitted via @json so a name/key with a
  # dot, quote, or space produces a correctly-quoted key (e.g. [mcp_servers."a.b"]) instead of
  # silently nesting into a sub-table or invalidating the block. Sub-table values are coerced to
  # strings (MCP env/headers are strings; a bare TOML number/bool would diverge from the Claude side).
  jq -r '
    .mcpServers // {} | to_entries[] |
    "[mcp_servers.\(.key|@json)]",
    (if .value.command then "command = \(.value.command|@json)" else empty end),
    (if .value.args    then "args = \(.value.args|@json)" else empty end),
    (if .value.url     then "url = \(.value.url|@json)" else empty end),
    (if .value.bearer_token_env_var then "bearer_token_env_var = \(.value.bearer_token_env_var|@json)" else empty end),
    (if (.value.env|type=="object")     then "[mcp_servers.\(.key|@json).env]",          (.value.env|to_entries[]|"\(.key|@json) = \(.value|tostring|@json)") else empty end),
    (if (.value.headers|type=="object") then "[mcp_servers.\(.key|@json).http_headers]",  (.value.headers|to_entries[]|"\(.key|@json) = \(.value|tostring|@json)") else empty end),
    ""
  ' "$EFFECTIVE"
  echo "$END"
} >> "$CODEX_TOML"

# Remote HTTP MCP support is required for any remaining direct HTTP servers and is harmless for
# stdio bridges. Keep this outside the managed MCP block so other config survives mcp-sync.
features_tmp=$(mktemp)
awk '
  BEGIN { in_features=0; seen_features=0; seen_key=0 }
  /^\[features\]$/ {
    if (in_features && !seen_key) print "experimental_use_rmcp_client = true"
    in_features=1
    seen_features=1
    seen_key=0
    print
    next
  }
  /^\[/ {
    if (in_features && !seen_key) print "experimental_use_rmcp_client = true"
    in_features=0
  }
  in_features && /^experimental_use_rmcp_client[[:space:]]*=/ {
    print  # keep the existing value — a deliberate `= false` (to dodge a Codex rmcp bug) must survive
    seen_key=1
    next
  }
  { print }
  END {
    if (in_features && !seen_key) print "experimental_use_rmcp_client = true"
    if (!seen_features) {
      print ""
      print "[features]"
      print "experimental_use_rmcp_client = true"
    }
  }
' "$CODEX_TOML" > "$features_tmp" && mv "$features_tmp" "$CODEX_TOML"

# Validate the generated Codex TOML and roll back if broken, so a parse error can't silently
# disable ALL Codex MCP servers. Prefer yq; fall back to Python's stdlib tomllib (3.11+). If
# NEITHER validator is available, fail CLOSED (restore backup) rather than ship unvalidated TOML.
codex_toml_valid() { # 0=valid, 1=invalid, 2=no validator available
  if command -v yq >/dev/null 2>&1; then
    yq -p toml "$1" >/dev/null 2>&1
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c 'import sys,tomllib; tomllib.load(open(sys.argv[1],"rb"))' "$1" >/dev/null 2>&1
  else
    return 2
  fi
}
if ! codex_toml_valid "$CODEX_TOML"; then
  rc=$?
  if [ "$rc" -eq 2 ]; then
    echo "ERROR: no TOML validator (yq or python3+tomllib) available — refusing to ship unvalidated Codex config; restoring backup" >&2
  else
    echo "ERROR: generated Codex TOML is invalid — restoring backup" >&2
  fi
  mv "$CODEX_TOML.mcp-sync.bak" "$CODEX_TOML"
  exit 1
fi

n=$(jq '.mcpServers // {} | length' "$EFFECTIVE")
src="$CANON"
[ -f "$LOCAL_OVERLAY" ] && src="$src + mcp.local.json"
echo "✓ mcp-sync: $n server(s) ← $src → Claude (~/.claude.json) + Codex (~/.codex/config.toml)"
