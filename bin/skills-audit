#!/usr/bin/env bash
# skills-audit — summarize installed shared skills, provenance, and executable surface.
set -euo pipefail
AH="${AGENTS_HOME:-$HOME/.config/agents}"
lock="$AH/skills.lock.json"

command -v jq >/dev/null || { echo "skills-audit: jq required" >&2; exit 1; }
[ -f "$lock" ] || { echo "skills-audit: missing $lock" >&2; exit 1; }

printf '%-36s %-30s %-10s %-8s %-12s %s\n' "skill" "source" "trust" "risk" "scripts" "commit"
jq -r '.skills | keys[]' "$lock" | while IFS= read -r name; do
	source=$(jq -r --arg n "$name" '.skills[$n].source' "$lock")
	commit=$(jq -r --arg n "$name" '.skills[$n].commit // "local"' "$lock")
	trust=$(jq -r --arg n "$name" '.skills[$n].trust // "unknown"' "$lock")
	risk=$(jq -r --arg n "$name" '.skills[$n].risk // (if (.skills[$n].trust // "") == "official" then "low" else "review" end)' "$lock")
	dir="$AH/skills/$name"
	if [ -d "$dir" ]; then
		scripts=$(find "$dir" -type f \( -name '*.sh' -o -name '*.py' -o -name '*.js' -o -name '*.ts' -o -name '*.ps1' -o -name '*.swift' \) 2>/dev/null | wc -l | tr -d ' ')
	else
		scripts="missing"
	fi
	printf '%-36s %-30s %-10s %-8s %-12s %.12s\n' "$name" "$source" "$trust" "$risk" "$scripts" "$commit"
	if [ "$risk" = "review" ] || [ "$trust" = "unknown" ]; then
		printf '  warn: %s needs explicit trust/risk metadata review\n' "$name" >&2
	fi
done
