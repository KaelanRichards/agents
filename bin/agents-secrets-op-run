#!/usr/bin/env bash
# agents-secrets-op-run — run a command with agent secrets resolved from 1Password.
set -euo pipefail

usage() {
	cat >&2 <<'EOF'
usage: agents-secrets-op-run [--env-file PATH] -- command [args...]

Resolves op:// secret references from an env file with `op run`, then execs command.
Default env file: ~/.config/agents-secrets/agents.1password.env

Optional bootstrap file:
  ~/.config/agents-secrets/1password-bootstrap.env

The bootstrap file may contain OP_SERVICE_ACCOUNT_TOKEN for unattended hosts. It must
be mode 0600 and is sourced only to authenticate `op`; it is not printed.
EOF
}

env_file="${AGENTS_1PASSWORD_ENV_FILE:-$HOME/.config/agents-secrets/agents.1password.env}"
bootstrap_file="${AGENTS_1PASSWORD_BOOTSTRAP_ENV:-$HOME/.config/agents-secrets/1password-bootstrap.env}"

while [ "$#" -gt 0 ]; do
	case "$1" in
	--env-file)
		[ "$#" -ge 2 ] || {
			usage
			exit 2
		}
		env_file="$2"
		shift 2
		;;
	--)
		shift
		break
		;;
	-h | --help)
		usage
		exit 0
		;;
	*)
		break
		;;
	esac
done

[ "$#" -gt 0 ] || {
	usage
	exit 2
}

command -v op >/dev/null 2>&1 || {
	echo "agents-secrets-op-run: op CLI is not installed" >&2
	exit 127
}

[ -f "$env_file" ] || {
	echo "agents-secrets-op-run: missing env ref file: $env_file" >&2
	exit 1
}

if [ -f "$bootstrap_file" ]; then
	mode="$(stat -f '%Lp' "$bootstrap_file" 2>/dev/null || stat -c '%a' "$bootstrap_file" 2>/dev/null || true)"
	if [ "$mode" != "600" ]; then
		echo "agents-secrets-op-run: refusing bootstrap file with mode $mode; run chmod 600 $bootstrap_file" >&2
		exit 1
	fi
	# Only honor a bootstrap file owned by the current user.
	owner="$(stat -f '%u' "$bootstrap_file" 2>/dev/null || stat -c '%u' "$bootstrap_file" 2>/dev/null || echo -1)"
	if [ "$owner" != "$(id -u)" ]; then
		echo "agents-secrets-op-run: refusing bootstrap file not owned by current user (owner uid=$owner)" >&2
		exit 1
	fi
	# Strict parse: extract ONLY OP_SERVICE_ACCOUNT_TOKEN. Never source the file as shell — a
	# tampered bootstrap file must not be able to execute arbitrary code in this process.
	tok=""
	while IFS= read -r line || [ -n "$line" ]; do
		case "$line" in
		OP_SERVICE_ACCOUNT_TOKEN=*) tok="${line#OP_SERVICE_ACCOUNT_TOKEN=}" ;;
		"export OP_SERVICE_ACCOUNT_TOKEN="*) tok="${line#export OP_SERVICE_ACCOUNT_TOKEN=}" ;;
		esac
	done <"$bootstrap_file"
	# Strip one layer of surrounding quotes if present.
	case "$tok" in
	\"*\")
		tok="${tok#\"}"
		tok="${tok%\"}"
		;;
	\'*\')
		tok="${tok#\'}"
		tok="${tok%\'}"
		;;
	esac
	[ -n "$tok" ] && export OP_SERVICE_ACCOUNT_TOKEN="$tok"
fi

exec op run --env-file "$env_file" -- "$@"
