#!/usr/bin/env bash
# agentp — launch a coding agent *under* a canonical permission profile, so the profile is a real
# boundary rather than advice.
#
# Claude (default): passes the profile's MCP subset with --strict-mcp-config (only those servers
#   load) and a compiled --settings file (deny/ask rules + native OS sandbox). It also exports
#   AGENTS_PROFILE so the profile-broker PreToolUse hook can enforce per-tool read/write policy
#   that settings alone can't express (e.g. allow datadog reads, deny datadog writes).
#     generated/profiles/claude/<profile>.mcp.json / .settings.json
#
# Codex (--codex): launches `codex` with the profile's native --sandbox + --ask-for-approval
#   (Codex's OS-enforced containment) AND `-c mcp_servers.<id>.enabled=false` for every server the
#   profile does not grant — so the MCP server subset is a real boundary on Codex too (parity with
#   Claude's --strict-mcp-config), not just advice. (Codex still lacks the per-tool read/write
#   broker hook, so within an allowed server, tool-level policy is approval-gated rather than denied.)
#
# Usage:
#   agentp <profile> [-- <extra claude args>]
#   agentp --codex <profile> [-- <extra codex args>]
#   agentp list            list available profiles
set -euo pipefail
AH="${AGENTS_HOME:-$HOME/.config/agents}"
CTL="$AH/scripts/agent_control.py"
GEN="$AH/generated/profiles/claude"

usage() {
	echo "usage: agentp [--codex] <profile> [-- <extra agent args>]" >&2
	echo "profiles:" >&2
	python3 "$CTL" profile list 2>/dev/null | sed 's/^/  /' >&2
}

engine="claude"
case "${1:-}" in
"" | -h | --help)
	usage
	exit 1
	;;
list)
	python3 "$CTL" profile list
	exit 0
	;;
--codex)
	engine="codex"
	shift
	;;
--claude)
	shift
	;;
esac

profile="${1:-}"
[ -n "$profile" ] || {
	usage
	exit 1
}
shift || true
[ "${1:-}" = "--" ] && shift

# Validate the profile name (exits non-zero on unknown).
python3 "$CTL" profile show "$profile" >/dev/null

if [ "$engine" = "codex" ]; then
	command -v codex >/dev/null 2>&1 || {
		echo "agentp: codex not on PATH" >&2
		exit 127
	}
	# shellcheck disable=SC2207  # intentional word-split: flags contain no spaces in values
	flags=($(python3 "$CTL" profile codex-flags "$profile"))
	export AGENTS_PROFILE="$profile"
	exec codex "${flags[@]}" "$@"
fi

# Claude: ensure compiled artifacts exist, then launch under the profile.
settings="$GEN/$profile.settings.json"
mcpcfg="$GEN/$profile.mcp.json"
if [ ! -f "$settings" ] || [ ! -f "$mcpcfg" ]; then
	python3 "$CTL" profile compile >/dev/null
fi
command -v claude >/dev/null 2>&1 || {
	echo "agentp: claude not on PATH" >&2
	exit 127
}
# AGENTS_PROFILE activates the profile-broker PreToolUse hook for this session.
export AGENTS_PROFILE="$profile"
exec claude \
	--settings "$settings" \
	--mcp-config "$mcpcfg" \
	--strict-mcp-config \
	--append-system-prompt "$(cat "$GEN/$profile.md")" \
	"$@"
