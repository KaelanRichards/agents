#!/usr/bin/env python3
"""Minimal Slack-DM MCP for the vizcom-sre VM runner (bot-token transport).

Least-privilege: DMs exactly one user (Kaelan) and reads that one DM thread. No Windmill,
no channels, no Gmail/Calendar. Mirrors the personal-actions ethos but Slack-only + direct.

Tools:
  slack_send_dm(text)          -> chat.postMessage to the configured DM target (a real send)
  slack_read_dm_thread(limit)  -> recent messages in that DM (fold Kaelan's corrections back in)

Env:
  SLACK_BOT_TOKEN   xoxb-...   (required)
  SLACK_DM_TARGET   Uxxxx      (default U04E9M9235G)

Slack app bot scopes: chat:write, im:write, im:history.
(im:history is what lets the bot read its OWN DM thread; search:read would need a user token.)
Needs: pip install mcp
"""

from __future__ import annotations

import json
import os
import urllib.parse
import urllib.request

from mcp.server.fastmcp import FastMCP

TOKEN = os.environ.get("SLACK_BOT_TOKEN", "")
TARGET = os.environ.get("SLACK_DM_TARGET", "U04E9M9235G")
mcp = FastMCP("slack-dm")


def _slack(method: str, payload: dict) -> dict:
    """POST to Slack with form-encoded body.

    Slack returns `missing_scope: channels:read` on conversations.list when the body is
    JSON, even when `types=im` is set (server-side scope check ignores the filter on the
    JSON path). Form-encoded respects the filter and accepts the narrower im:read scope.
    Slack's own docs recommend form encoding for list endpoints, so we use it for all
    calls — chat.postMessage accepts either.
    """
    flat = {
        k: (json.dumps(v) if isinstance(v, (list, dict)) else str(v))
        for k, v in payload.items()
    }
    req = urllib.request.Request(
        f"https://slack.com/api/{method}",
        data=urllib.parse.urlencode(flat).encode("utf-8"),
        headers={
            "Authorization": f"Bearer {TOKEN}",
            "Content-Type": "application/x-www-form-urlencoded; charset=utf-8",
        },
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=20) as resp:  # noqa: S310
        return json.loads(resp.read().decode("utf-8"))


def _dm_channel() -> str:
    """Find the existing DM channel with TARGET via conversations.list (needs im:read).

    Avoids conversations.open (which needs im:write). The DM channel must already exist —
    Kaelan must have DM'd the bot once to create it (Slack API does not let bots initiate).
    """
    cursor = ""
    while True:
        params: dict = {"types": "im", "limit": 200}
        if cursor:
            params["cursor"] = cursor
        res = _slack("conversations.list", params)
        if not res.get("ok"):
            raise RuntimeError(f"conversations.list failed: {res.get('error')}")
        for c in res.get("channels", []):
            if c.get("user") == TARGET:
                return c["id"]
        cursor = res.get("response_metadata", {}).get("next_cursor", "")
        if not cursor:
            break
    raise RuntimeError(
        f"no DM channel with user {TARGET}; the user must DM the bot once to open the conversation"
    )


@mcp.tool()
def slack_send_dm(text: str) -> str:
    """Send ONE DM to Kaelan (SLACK_DM_TARGET). This is a real, live send."""
    if not TOKEN:
        return json.dumps({"ok": False, "error": "SLACK_BOT_TOKEN not set"})
    res = _slack("chat.postMessage", {"channel": _dm_channel(), "text": text})
    return json.dumps(
        {"ok": bool(res.get("ok")), "ts": res.get("ts"), "error": res.get("error")}
    )


@mcp.tool()
def slack_read_dm_thread(limit: int = 20) -> str:
    """Read recent messages + reactions in Kaelan's DM, to fold corrections into the brain.

    Each returned message includes `reactions` (list of {name, users, count}) when set.
    Kaelan ✅-ing or ❌-ing a bot digest line is the lowest-friction correction signal —
    see runbooks/reaction-corrections.md for the mapping. Read-only.
    """
    if not TOKEN:
        return json.dumps({"ok": False, "error": "SLACK_BOT_TOKEN not set"})
    res = _slack("conversations.history", {"channel": _dm_channel(), "limit": limit})
    msgs = [
        {
            "user": m.get("user"),
            "text": m.get("text"),
            "ts": m.get("ts"),
            "reactions": [
                {
                    "name": r.get("name"),
                    "users": r.get("users", []),
                    "count": r.get("count", 0),
                }
                for r in m.get("reactions", [])
            ],
        }
        for m in res.get("messages", [])
    ]
    return json.dumps(
        {"ok": bool(res.get("ok")), "messages": msgs, "error": res.get("error")}
    )


if __name__ == "__main__":
    mcp.run()
