#!/usr/bin/env python3
"""Minimal Slack-DM MCP for the vizcom-sre VM runner (bot-token transport)."""

from __future__ import annotations

import json
import os
import sys
import urllib.parse
import urllib.request

def _secret(key: str, default: str = "") -> str:
    """Return key from env, else from the chmod-600 agents-secrets files.

    The env path is normal (run-tick.sh exports these, and Claude propagates the
    parent env to stdio MCP children). The file fallback exists because the Codex
    fallback runtime does NOT pass the parent env to MCP children, so a
    Codex-spawned slack-dm would otherwise start tokenless and every DM would
    fail. No secret is stored in tracked config; env always wins when present.
    """
    val = os.environ.get(key, "")
    if val:
        return val
    for name in ("kaelan-pa-slack.env", "kaelan-pa.env", "vizcom-sre.env"):
        path = os.path.expanduser(f"~/.config/agents-secrets/{name}")
        try:
            with open(path, encoding="utf-8") as fh:
                for line in fh:
                    line = line.strip()
                    if not line or line.startswith("#") or "=" not in line:
                        continue
                    name_, _, raw = line.partition("=")
                    if name_.strip() == key:
                        return raw.strip().strip("'\"")
        except OSError:
            continue
    return default


TOKEN = _secret("SLACK_BOT_TOKEN")
TARGET = _secret("SLACK_DM_TARGET", "U04E9M9235G")


def _read_message() -> dict | None:
    line = sys.stdin.buffer.readline()
    if not line:
        return None

    if line.startswith(b"Content-Length:"):
        length = int(line.split(b":", 1)[1].strip())
        while True:
            line = sys.stdin.buffer.readline()
            if line in {b"\n", b"\r\n", b""}:
                break
        return json.loads(sys.stdin.buffer.read(length).decode("utf-8"))

    return json.loads(line.decode("utf-8"))


def _write_message(message: dict) -> None:
    body = json.dumps(message, separators=(",", ":")).encode("utf-8")
    sys.stdout.buffer.write(b"Content-Length: " + str(len(body)).encode("ascii") + b"\r\n\r\n" + body)
    sys.stdout.buffer.flush()


def _slack(method: str, payload: dict) -> dict:
    flat = {
        k: (json.dumps(v) if isinstance(v, (list, dict)) else str(v))
        for k, v in payload.items()
    }
    req = urllib.request.Request(
        f"https://slack.com/api/{method}",
        data=urllib.parse.urlencode(flat).encode("utf-8"),
        headers={
            "Authorization": f"Bearer {TOKEN}",
            "Content-Type": "application/x-www-form-urlencoded; charset=utf-8",
        },
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=20) as resp:  # noqa: S310
        return json.loads(resp.read().decode("utf-8"))


def _dm_channel() -> str:
    cursor = ""
    while True:
        params: dict = {"types": "im", "limit": 200}
        if cursor:
            params["cursor"] = cursor
        res = _slack("conversations.list", params)
        if not res.get("ok"):
            raise RuntimeError(f"conversations.list failed: {res.get('error')}")
        for channel in res.get("channels", []):
            if channel.get("user") == TARGET:
                return channel["id"]
        cursor = res.get("response_metadata", {}).get("next_cursor", "")
        if not cursor:
            break
    raise RuntimeError(
        f"no DM channel with user {TARGET}; the user must DM the bot once to open the conversation"
    )


def _send_dm(args: dict) -> dict:
    if not TOKEN:
        return {"ok": False, "error": "SLACK_BOT_TOKEN not set"}
    res = _slack("chat.postMessage", {"channel": _dm_channel(), "text": args.get("text", "")})
    return {"ok": bool(res.get("ok")), "ts": res.get("ts"), "error": res.get("error")}


def _read_dm(args: dict) -> dict:
    if not TOKEN:
        return {"ok": False, "error": "SLACK_BOT_TOKEN not set", "messages": []}
    res = _slack("conversations.history", {"channel": _dm_channel(), "limit": args.get("limit", 20)})
    messages = [
        {
            "user": message.get("user"),
            "text": message.get("text"),
            "ts": message.get("ts"),
            "reactions": [
                {
                    "name": reaction.get("name"),
                    "users": reaction.get("users", []),
                    "count": reaction.get("count", 0),
                }
                for reaction in message.get("reactions", [])
            ],
        }
        for message in res.get("messages", [])
    ]
    return {"ok": bool(res.get("ok")), "messages": messages, "error": res.get("error")}


TOOLS = [
    {
        "name": "slack_send_dm",
        "description": "Send one DM to Kaelan (SLACK_DM_TARGET). This is a real, live send.",
        "inputSchema": {
            "type": "object",
            "properties": {"text": {"type": "string"}},
            "required": ["text"],
            "additionalProperties": False,
        },
    },
    {
        "name": "slack_read_dm_thread",
        "description": "Read recent messages and reactions in Kaelan's DM.",
        "inputSchema": {
            "type": "object",
            "properties": {"limit": {"type": "integer", "minimum": 1, "maximum": 100, "default": 20}},
            "additionalProperties": False,
        },
    },
]


def _tool_result(payload: dict) -> dict:
    return {"content": [{"type": "text", "text": json.dumps(payload)}]}


def main() -> None:
    while True:
        try:
            message = _read_message()
        except Exception:  # noqa: BLE001
            # Malformed/partial frame (bad Content-Length, invalid JSON): skip it and keep serving
            # rather than crashing the process on one bad byte.
            continue
        if message is None:  # EOF — client closed the pipe
            return
        if not isinstance(message, dict):
            continue

        message_id = message.get("id")
        method = message.get("method")
        if message_id is None:
            continue

        try:
            if method == "initialize":
                params = message.get("params") or {}
                result = {
                    "protocolVersion": params.get("protocolVersion", "2025-06-18"),
                    "capabilities": {"tools": {"listChanged": False}},
                    "serverInfo": {"name": "slack-dm", "version": "0.1.0"},
                }
            elif method == "tools/list":
                result = {"tools": TOOLS}
            elif method == "tools/call":
                params = message.get("params") or {}
                arguments = params.get("arguments") or {}
                if params.get("name") == "slack_send_dm":
                    result = _tool_result(_send_dm(arguments))
                elif params.get("name") == "slack_read_dm_thread":
                    result = _tool_result(_read_dm(arguments))
                else:
                    raise ValueError(f"unknown tool {params.get('name')}")
            else:
                _write_message(
                    {
                        "jsonrpc": "2.0",
                        "id": message_id,
                        "error": {"code": -32601, "message": f"unknown method {method}"},
                    }
                )
                continue
            _write_message({"jsonrpc": "2.0", "id": message_id, "result": result})
        except Exception as exc:  # noqa: BLE001
            _write_message(
                {
                    "jsonrpc": "2.0",
                    "id": message_id,
                    "error": {"code": -32000, "message": str(exc)},
                }
            )


if __name__ == "__main__":
    main()
