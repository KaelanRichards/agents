#!/usr/bin/env bash
# windmill-down — stop the local Windmill backend.
set -euo pipefail

AH="${AGENTS_HOME:-$HOME/.config/agents}"
stack="$AH/stacks/windmill"
env_file="${WINDMILL_ENV_FILE:-$HOME/.config/agents-secrets/windmill.env}"

docker compose --env-file "$env_file" --file "$stack/docker-compose.yml" down "$@"
