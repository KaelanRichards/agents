#!/usr/bin/env bash
# agents-doctor — health check for the shared agent environment (laptop + VM).
# Verifies tools, symlinks, MCP parity, config validity, hooks, and agent-CLI version drift.
# Exit non-zero on any error (CI-friendly). Run anytime:  agents-doctor
set -uo pipefail
AH="${AGENTS_HOME:-$HOME/.config/agents}"
ERR=0
WARN=0
bad() {
	printf '  [FAIL] %s\n' "$1"
	ERR=$((ERR + 1))
}
warn() {
	printf '  [warn] %s\n' "$1"
	WARN=$((WARN + 1))
}
ok() { printf '  [ ok ] %s\n' "$1"; }

echo "== tools =="
missing=""
for t in jj git mise uv rg fd fzf jq yq ast-grep sd gron bat eza tree scc ruff biome shellcheck shfmt gitleaks just watchexec entr hyperfine xh pandoc starship gh delta; do
	command -v "$t" >/dev/null 2>&1 || missing="$missing $t"
done
[ -z "$missing" ] && ok "core toolbelt present" || bad "missing tools:$missing"
for t in claude codex; do
	command -v "$t" >/dev/null 2>&1 && ok "$t present" || warn "$t not on PATH"
done

echo "== instruction symlinks =="
for f in "$HOME/.claude/CLAUDE.md" "$HOME/.codex/AGENTS.md"; do
	[ "$(readlink "$f" 2>/dev/null)" = "$AH/AGENTS.md" ] && ok "${f/#"$HOME"/~} -> AGENTS.md" || bad "${f/#"$HOME"/~} not linked to canonical AGENTS.md"
done

echo "== helper scripts on PATH =="
for s in "$AH"/bin/*; do
	n=$(basename "$s")
	[ -x "$HOME/.local/bin/$n" ] && ok "$n" || warn "$n not on ~/.local/bin (run bootstrap or re-link)"
done

echo "== MCP parity =="
if command -v jq >/dev/null 2>&1; then
	c=$(jq '.mcpServers // {} | length' "$AH/mcp.json" 2>/dev/null || echo -1)
	cl=$(jq '.mcpServers // {} | length' "$HOME/.claude.json" 2>/dev/null || echo -1)
	cx=$(grep -cE '^\[mcp_servers\.[^.]+\]$' "$HOME/.codex/config.toml" 2>/dev/null || echo -1)
	[ "$c" = "$cl" ] && [ "$c" = "$cx" ] && ok "MCP servers in sync ($c)" || bad "MCP parity mismatch: canonical=$c claude=$cl codex=$cx (run mcp-sync)"
fi

echo "== config validity =="
jq -e . "$AH/mcp.json" >/dev/null 2>&1 && ok "mcp.json" || bad "mcp.json invalid JSON"
[ -f "$HOME/.claude/settings.json" ] && { jq -e . "$HOME/.claude/settings.json" >/dev/null 2>&1 && ok "claude settings.json" || bad "claude settings.json invalid"; }
if command -v yq >/dev/null 2>&1 && [ -f "$HOME/.codex/config.toml" ]; then
	yq -p toml "$HOME/.codex/config.toml" >/dev/null 2>&1 && ok "codex config.toml" || bad "codex config.toml invalid TOML"
fi
command -v jj >/dev/null 2>&1 && { jj config list --user >/dev/null 2>&1 && ok "jj config" || bad "jj config invalid"; }

echo "== hooks =="
if [ -f "$HOME/.claude/settings.json" ]; then
	jq -e '.hooks.PreToolUse and .hooks.PostToolUse' "$HOME/.claude/settings.json" >/dev/null 2>&1 && ok "claude hooks wired" || warn "claude hooks not wired (run agents-sync)"
fi

echo "== agent-CLI version drift =="
vfile="$AH/.doctor-versions"
cur=$(mktemp)
{
	command -v claude >/dev/null 2>&1 && claude --version 2>/dev/null | head -1
	command -v codex >/dev/null 2>&1 && codex --version 2>/dev/null | head -1
} >"$cur"
if [ -f "$vfile" ]; then
	diff -q "$vfile" "$cur" >/dev/null 2>&1 && ok "agent CLI versions unchanged" || { warn "agent CLI version changed — re-verify mcp-sync/agents-sync output"; cp "$cur" "$vfile"; }
else
	cp "$cur" "$vfile"
	ok "recorded agent CLI version baseline"
fi
rm -f "$cur"

echo
[ "$ERR" -gt 0 ] && {
	echo "FAILED: $ERR error(s), $WARN warning(s)"
	exit 1
}
echo "HEALTHY: 0 errors, $WARN warning(s)"
