#!/usr/bin/env bash
# agents-doctor — health check for the shared agent environment (laptop + VM).
# Verifies tools, symlinks, MCP parity, config validity, hooks, and agent-CLI version drift.
# Exit non-zero on any error (CI-friendly). Run anytime:  agents-doctor
set -uo pipefail
AH="${AGENTS_HOME:-$HOME/.config/agents}"
ERR=0
WARN=0
bad() {
	printf '  [FAIL] %s\n' "$1"
	ERR=$((ERR + 1))
}
warn() {
	printf '  [warn] %s\n' "$1"
	WARN=$((WARN + 1))
}
ok() { printf '  [ ok ] %s\n' "$1"; }

echo "== tools =="
missing=""
for t in jj git mise uv rg fd fzf jq yq ast-grep sd gron bat eza tree scc ruff biome shellcheck shfmt gitleaks just watchexec entr hyperfine xh pandoc starship gh delta; do
	command -v "$t" >/dev/null 2>&1 || missing="$missing $t"
done
[ -z "$missing" ] && ok "core toolbelt present" || bad "missing tools:$missing"
for t in claude codex; do
	command -v "$t" >/dev/null 2>&1 && ok "$t present" || warn "$t not on PATH"
done
command -v hermes >/dev/null 2>&1 && ok "hermes present" || warn "hermes not on PATH"
command -v op >/dev/null 2>&1 && ok "op present" || warn "op not on PATH (needed for 1Password-backed agent secrets)"

echo "== instruction symlinks =="
for f in "$HOME/.claude/CLAUDE.md" "$HOME/.codex/AGENTS.md"; do
	[ "$(readlink "$f" 2>/dev/null)" = "$AH/AGENTS.md" ] && ok "${f/#"$HOME"/~} -> AGENTS.md" || bad "${f/#"$HOME"/~} not linked to canonical AGENTS.md"
done

echo "== helper scripts on PATH =="
for s in "$AH"/bin/*; do
	n=$(basename "$s")
	[ -x "$HOME/.local/bin/$n" ] && ok "$n" || warn "$n not on ~/.local/bin (run bootstrap or re-link)"
done

echo "== MCP parity =="
if command -v jq >/dev/null 2>&1; then
	c=$(jq '.mcpServers // {} | length' "$AH/mcp.json" 2>/dev/null || echo -1)
	cl=$(jq '.mcpServers // {} | length' "$HOME/.claude.json" 2>/dev/null || echo -1)
	cx=$(grep -cE '^\[mcp_servers\.[^.]+\]$' "$HOME/.codex/config.toml" 2>/dev/null || echo -1)
	[ "$c" = "$cl" ] && [ "$c" = "$cx" ] && ok "MCP servers in sync ($c)" || bad "MCP parity mismatch: canonical=$c claude=$cl codex=$cx (run mcp-sync)"
	required_mcp="context7 playwright filesystem sequential-thinking github datadog sentry bigquery agents agent-broker personal-actions linear"
	for s in $required_mcp; do
		jq -e --arg s "$s" '.mcpServers[$s]' "$AH/mcp.json" >/dev/null 2>&1 && ok "MCP required server present: $s" || bad "missing required MCP server: $s"
	done
	jq -e '.mcpServers.linear.url == "https://mcp.linear.app/mcp"' "$AH/mcp.json" >/dev/null 2>&1 && ok "Linear MCP URL pinned" || bad "Linear MCP URL mismatch"
	jq -e '.mcpServers.datadog.url == "https://mcp.us5.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=core,apm,error-tracking,software-delivery"' "$AH/mcp.json" >/dev/null 2>&1 && ok "Datadog MCP US5 URL pinned" || bad "Datadog MCP URL mismatch"
	jq -e '.mcpServers.sentry.url == "https://mcp.sentry.dev/mcp"' "$AH/mcp.json" >/dev/null 2>&1 && ok "Sentry MCP URL pinned" || bad "Sentry MCP URL mismatch"
	# Accept either an $AGENTS_HOME placeholder (portable canonical) or an absolute path to $AH/bin/bigquery-mcp.
	bq_cmd=$(jq -r '.mcpServers.bigquery.command // ""' "$AH/mcp.json" 2>/dev/null)
	if [ "$bq_cmd" = "\$AGENTS_HOME/bin/bigquery-mcp" ] || [ "$bq_cmd" = "$AH/bin/bigquery-mcp" ]; then
		ok "BigQuery MCP local facade pinned"
	else
		bad "BigQuery MCP command mismatch (got: $bq_cmd)"
	fi
fi

echo "== config validity =="
jq -e . "$AH/mcp.json" >/dev/null 2>&1 && ok "mcp.json" || bad "mcp.json invalid JSON"
[ -f "$HOME/.claude/settings.json" ] && { jq -e . "$HOME/.claude/settings.json" >/dev/null 2>&1 && ok "claude settings.json" || bad "claude settings.json invalid"; }
if command -v yq >/dev/null 2>&1 && [ -f "$HOME/.codex/config.toml" ]; then
	yq -p toml "$HOME/.codex/config.toml" >/dev/null 2>&1 && ok "codex config.toml" || bad "codex config.toml invalid TOML"
	if grep -qF '[mcp_servers.linear]' "$HOME/.codex/config.toml"; then
		grep -qF 'experimental_use_rmcp_client = true' "$HOME/.codex/config.toml" && ok "codex remote MCP feature enabled" || bad "codex Linear MCP requires experimental_use_rmcp_client = true"
	fi
fi
command -v jj >/dev/null 2>&1 && { jj config list --user >/dev/null 2>&1 && ok "jj config" || bad "jj config invalid"; }

echo "== hooks =="
if [ -f "$HOME/.claude/settings.json" ]; then
	jq -e '.hooks.PreToolUse and .hooks.PostToolUse' "$HOME/.claude/settings.json" >/dev/null 2>&1 && ok "claude hooks wired" || warn "claude hooks not wired (run agents-sync)"
fi
if [ -f "$HOME/.codex/config.toml" ]; then
	if grep -qF '[[hooks.PreToolUse]]' "$HOME/.codex/config.toml" && grep -qF '[[hooks.PostToolUse]]' "$HOME/.codex/config.toml"; then
		ok "codex hooks wired"
	else
		warn "codex hooks not wired (run agents-sync)"
	fi
fi

echo "== agent control plane =="
if command -v agent-profile >/dev/null 2>&1; then
	agent-profile validate >/dev/null 2>&1 && ok "agent profiles valid" || bad "agent profiles invalid"
else
	warn "agent-profile not on PATH"
fi
if command -v agent-eval >/dev/null 2>&1; then
	agent-eval list >/dev/null 2>&1 && ok "agent eval tasks readable" || bad "agent eval tasks unreadable"
else
	warn "agent-eval not on PATH"
fi
if [ -x "$AH/bin/agent-broker-mcp" ]; then
	ok "agent-broker MCP launcher present"
else
	bad "agent-broker MCP launcher missing"
fi

echo "== skill sync =="
canonical_skills=$(find "$AH/skills" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
claude_skills=$(find "$HOME/.claude/skills" -mindepth 1 -maxdepth 1 -type l 2>/dev/null | wc -l | tr -d ' ')
codex_skills=$(find "$HOME/.codex/skills" -mindepth 1 -maxdepth 1 -type l 2>/dev/null | wc -l | tr -d ' ')
if [ "$canonical_skills" = "$claude_skills" ] && [ "$canonical_skills" = "$codex_skills" ]; then
	ok "canonical skills linked to Claude + Codex ($canonical_skills)"
else
	bad "skill count mismatch: canonical=$canonical_skills claude=$claude_skills codex=$codex_skills (run agents-sync)"
fi
broken_skills=$(find "$HOME/.claude/skills" "$HOME/.codex/skills" -mindepth 1 -maxdepth 1 -type l ! -exec test -e {} \; -print 2>/dev/null | wc -l | tr -d ' ')
[ "$broken_skills" = "0" ] && ok "no broken skill links" || bad "broken skill symlinks: $broken_skills"
if [ -f "$AH/skills.lock.json" ]; then
	lock_skills=$(jq '.skills | length' "$AH/skills.lock.json" 2>/dev/null || echo -1)
	[ "$lock_skills" = "$canonical_skills" ] && ok "skills.lock.json covers all canonical skills" || bad "skills.lock.json count mismatch: lock=$lock_skills canonical=$canonical_skills"
else
	bad "missing skills.lock.json"
fi

echo "== Hermes personal assistant =="
if command -v hermes >/dev/null 2>&1; then
	[ -f "$HOME/.hermes/config.yaml" ] && ok "hermes config.yaml present" || warn "hermes config.yaml missing (run hermes-sync)"
	if hermes mcp list 2>/dev/null | grep -q "agents_readonly"; then
		ok "hermes agents_readonly MCP configured"
	else
		warn "hermes agents_readonly MCP missing (run hermes-sync)"
	fi
	if hermes mcp list 2>/dev/null | grep -q "personal_actions"; then
		ok "hermes personal_actions MCP configured"
	else
		warn "hermes personal_actions MCP missing (run hermes-sync)"
	fi
	if [ "${PERSONAL_ACTIONS_DRY_RUN:-1}" = "0" ] || [ -n "${PERSONAL_ACTIONS_WEBHOOK_URL:-}" ]; then
		ok "personal actions live provider env present"
	else
		ok "personal actions default to dry-run"
	fi
	if [ -f "$HOME/.hermes/config.yaml" ]; then
		for tool in personal_slack_send_message personal_slack_search_messages personal_gmail_search_messages personal_gmail_get_message personal_gmail_create_draft personal_gmail_send_email personal_gmail_trash_email personal_calendar_list_events personal_calendar_create_event personal_calendar_update_event personal_drive_search_files; do
			grep -qF -- "- $tool" "$HOME/.hermes/config.yaml" && ok "hermes personal action tool: $tool" || bad "hermes missing personal action tool: $tool"
		done
	fi
else
	warn "Hermes not installed"
fi

echo "== personal action auth =="
pa_env="$HOME/.config/agents-secrets/personal-actions.env"
if [ -f "$pa_env" ]; then
	for key in PERSONAL_GMAIL_COMPOSE_REFRESH_TOKEN PERSONAL_GMAIL_MODIFY_REFRESH_TOKEN PERSONAL_WORK_GMAIL_MODIFY_REFRESH_TOKEN; do
		if awk -F= -v k="$key" '$1==k && length($2)>0 {found=1} END {exit found?0:1}' "$pa_env"; then
			ok "$key configured"
		else
			warn "$key missing"
		fi
	done
	if awk -F= '$1=="PERSONAL_WORK_GMAIL_COMPOSE_REFRESH_TOKEN" && length($2)>0 {found=1} END {exit found?0:1}' "$pa_env"; then
		ok "PERSONAL_WORK_GMAIL_COMPOSE_REFRESH_TOKEN configured"
	else
		warn "PERSONAL_WORK_GMAIL_COMPOSE_REFRESH_TOKEN missing (run personal-actions-google-compose-auth --account work if work drafts are needed)"
	fi
else
	warn "missing $pa_env"
fi

echo "== 1Password agent secrets =="
op_refs="$HOME/.config/agents-secrets/agents.1password.env"
op_bootstrap="$HOME/.config/agents-secrets/1password-bootstrap.env"
if command -v op >/dev/null 2>&1; then
	ok "op CLI available"
	if [ -n "${OP_SERVICE_ACCOUNT_TOKEN:-}" ]; then
		ok "OP_SERVICE_ACCOUNT_TOKEN present in environment"
	elif [ -f "$op_bootstrap" ]; then
		mode="$(stat -f '%Lp' "$op_bootstrap" 2>/dev/null || stat -c '%a' "$op_bootstrap" 2>/dev/null || true)"
		if [ "$mode" = "600" ]; then
			ok "1Password bootstrap env mode 600"
		else
			warn "1Password bootstrap env mode is ${mode:-unknown}; expected 600"
		fi
	elif op account list --format json 2>/dev/null | jq -e 'length > 0' >/dev/null 2>&1; then
		ok "interactive 1Password account configured"
	else
		warn "1Password installed but no account/session or service-account bootstrap configured"
	fi
	if [ -f "$op_refs" ]; then
		ok "agents.1password.env present"
	else
		warn "agents.1password.env missing (see assistant/1password-secrets.md)"
	fi
else
	warn "op CLI unavailable; 1Password secret references cannot resolve"
fi

echo "== BigQuery auth =="
if command -v gcloud >/dev/null 2>&1 && command -v bq >/dev/null 2>&1; then
	bq_project=$(gcloud config get-value project 2>/dev/null || true)
	[ "$bq_project" = "vizcom-web" ] && ok "gcloud active project: vizcom-web" || warn "gcloud active project is ${bq_project:-unset}; expected vizcom-web"
	bq_account=$(gcloud auth list --filter=status:ACTIVE --format='value(account)' 2>/dev/null || true)
	[ -n "$bq_account" ] && ok "gcloud active account: $bq_account" || warn "no active gcloud account"
	if bq --project_id=vizcom-web query --use_legacy_sql=false --format=prettyjson 'SELECT 1 AS ok' >/dev/null 2>&1; then
		ok "BigQuery read query works"
	else
		warn "BigQuery read query failed; run gcloud auth login and verify vizcom-web IAM"
	fi
else
	warn "gcloud/bq not installed"
fi

echo "== repo sync =="
if command -v jj >/dev/null 2>&1 && jj -R "$AH" root >/dev/null 2>&1; then
	current_bookmarks=$(jj -R "$AH" log -r @ --no-graph -T 'bookmarks.join(" ")' 2>/dev/null || true)
	[ -n "$current_bookmarks" ] && ok "current config change has bookmark(s): $current_bookmarks" || warn "current config change has no bookmark"
fi

echo "== agent-CLI version drift =="
vfile="$AH/.doctor-versions"
cur=$(mktemp)
{
	command -v claude >/dev/null 2>&1 && claude --version 2>/dev/null | head -1
	command -v codex >/dev/null 2>&1 && codex --version 2>/dev/null | head -1
} >"$cur"
if [ -f "$vfile" ]; then
	diff -q "$vfile" "$cur" >/dev/null 2>&1 && ok "agent CLI versions unchanged" || { warn "agent CLI version changed — re-verify mcp-sync/agents-sync output"; cp "$cur" "$vfile"; }
else
	cp "$cur" "$vfile"
	ok "recorded agent CLI version baseline"
fi
rm -f "$cur"

echo "== container runtime (local dev) =="
if command -v docker >/dev/null 2>&1; then
	if docker info >/dev/null 2>&1; then ok "docker present + daemon running"
	else warn "docker on PATH but daemon not running (OrbStack: 'orb start')"; fi
elif command -v orb >/dev/null 2>&1; then
	warn "OrbStack installed but 'docker' not on PATH (run 'orb start')"
else
	warn "no container runtime (docker/OrbStack) — needed to run local service deps"
fi

echo "== agent shell PATH (non-interactive zsh) =="
# the agent Bash tool runs commands in a non-interactive shell; it must resolve the toolchain
# without a manual `eval "$(brew shellenv)"`. This catches a missing/broken ~/.zshenv wiring.
if command -v zsh >/dev/null 2>&1; then
	miss=""
	for t in node rg jq; do zsh -c "command -v $t" >/dev/null 2>&1 || miss="$miss $t"; done
	[ -z "$miss" ] && ok "non-interactive zsh resolves toolchain (node/rg/jq)" ||
		bad "non-interactive zsh missing:$miss — wire ~/.zshenv -> agents.env.zsh (run bootstrap)"
else
	warn "zsh not installed — agent shell PATH check skipped"
fi

echo
[ "$ERR" -gt 0 ] && {
	echo "FAILED: $ERR error(s), $WARN warning(s)"
	exit 1
}
echo "HEALTHY: 0 errors, $WARN warning(s)"
