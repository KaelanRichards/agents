#!/usr/bin/env bash
# agents-link — in a target repo, make AGENTS.md the source of truth and
# symlink CLAUDE.md -> AGENTS.md, so Claude Code and Codex share one project file.
#
# Usage:
#   agents-link              run in the current directory (default)
#   agents-link -C <path>    run in <path> instead
#   agents-link --check      verify the convention without changing anything (exit 1 on drift)
set -euo pipefail

target="."
check_only=0
while [ $# -gt 0 ]; do
	case "$1" in
	-C)
		[ -n "${2:-}" ] || {
			echo "agents-link: -C requires a path" >&2
			exit 2
		}
		target="$2"
		shift 2
		;;
	--check)
		check_only=1
		shift
		;;
	-h | --help)
		sed -n '2,8p' "$0" | sed 's/^# \{0,1\}//'
		exit 0
		;;
	*)
		echo "agents-link: unknown arg '$1' (try: agents-link --help)" >&2
		exit 2
		;;
	esac
done

[ -d "$target" ] || {
	echo "agents-link: '$target' is not a directory" >&2
	exit 1
}
cd "$target"

if [ "$check_only" -eq 1 ]; then
	# Verify-only: AGENTS.md is a real file and CLAUDE.md is a symlink -> AGENTS.md.
	if [ ! -e AGENTS.md ]; then
		echo "agents-link: $PWD: AGENTS.md is missing" >&2
		exit 1
	fi
	if [ -L AGENTS.md ]; then
		echo "agents-link: $PWD: AGENTS.md must be a real file, not a symlink" >&2
		exit 1
	fi
	if [ ! -L CLAUDE.md ]; then
		if [ -e CLAUDE.md ]; then
			echo "agents-link: $PWD: CLAUDE.md is a standalone real file; should be a symlink -> AGENTS.md" >&2
		else
			echo "agents-link: $PWD: CLAUDE.md symlink is missing (run agents-link)" >&2
		fi
		exit 1
	fi
	# Accept any symlink form (relative, ./, or absolute) as long as it resolves to AGENTS.md.
	if ! [ CLAUDE.md -ef AGENTS.md ]; then
		echo "agents-link: $PWD: CLAUDE.md points to '$(readlink CLAUDE.md)', does not resolve to AGENTS.md" >&2
		exit 1
	fi
	exit 0
fi

if [ ! -e AGENTS.md ]; then
	printf '# Project agent instructions\n\n' >AGENTS.md
	echo "created AGENTS.md in $PWD"
fi

if [ -L CLAUDE.md ] || [ ! -e CLAUDE.md ]; then
	ln -sf AGENTS.md CLAUDE.md
	echo "linked CLAUDE.md -> AGENTS.md in $PWD"
else
	echo "CLAUDE.md in $PWD is a real file; merge its contents into AGENTS.md, delete it, then re-run." >&2
	exit 1
fi
