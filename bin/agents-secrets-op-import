#!/usr/bin/env bash
# agents-secrets-op-import — import existing local agents env secrets into 1Password.
set -euo pipefail

vault="${AGENTS_1PASSWORD_VAULT:-Kaelan-Agents}"
apply="0"
write_env="0"

usage() {
	cat >&2 <<'EOF'
usage: agents-secrets-op-import [--vault "Kaelan-Agents"] [--apply] [--write-env]

Imports existing ~/.config/agents-secrets/*.env values into 1Password items.
Default mode is a dry-run that prints only item/field names, never values.
--write-env rewrites ~/.config/agents-secrets/agents.1password.env with only
references for values found locally, so op run does not fail on optional items.

This command must run in a terminal where `op account list` works.
EOF
}

while [ "$#" -gt 0 ]; do
	case "$1" in
	--vault)
		[ "$#" -ge 2 ] || {
			usage
			exit 2
		}
		vault="$2"
		shift 2
		;;
	--apply)
		apply="1"
		shift
		;;
	--write-env)
		write_env="1"
		shift
		;;
	-h | --help)
		usage
		exit 0
		;;
	*)
		usage
		exit 2
		;;
	esac
done

command -v op >/dev/null 2>&1 || {
	echo "agents-secrets-op-import: op CLI is not installed" >&2
	exit 127
}

args=(--vault "$vault")
if [ "$apply" = "1" ]; then
	args+=(--apply)
fi
if [ "$write_env" = "1" ]; then
	args+=(--write-env)
fi

python3 "$HOME/.config/agents/scripts/agents_secrets_op_import.py" "${args[@]}"
